# --- Database ---
DATABASE_URL=postgresql+psycopg://travelbud:travelbud@localhost:5432/travelbud

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# --- LLM (required for itinerary generation + translation) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Google Maps (optional; static sample attractions are used when unset) ---
GOOGLE_MAPS_API_KEY=

# --- Pricing provider: "mock" (default, no keys needed) or "amadeus" ---
PRICING_PROVIDER=mock
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- PDF storage: "local" (default) or "s3" ---
STORAGE_BACKEND=local
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Seed data (created by `python -m app.db.seed`) ---
SEED_ADMIN_EMAIL=admin@travelbud.dev
SEED_ADMIN_PASSWORD=admin12345

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
