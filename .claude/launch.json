{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && DATABASE_URL='sqlite:///./dev.db' JWT_SECRET='dev-verify-secret' .venv/bin/uvicorn app.main:app --port 8001"],
      "port": 8001
    },
    {
      "name": "web",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd frontend && API_INTERNAL_URL='http://localhost:8001' npm run dev"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
